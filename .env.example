# Retell AI API Key — from dashboard.retellai.com → Settings → API Keys
RETELL_API_KEY=

# Optional: Path to SQLite database file
# On Railway, set this to /data/callers.db and add a persistent volume mounted at /data
# Leave blank for local dev (defaults to ./callers.db)
DB_PATH=

# Port — Railway sets this automatically, leave blank locally
PORT=
